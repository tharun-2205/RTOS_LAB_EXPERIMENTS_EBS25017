void StartDefaultTask(void *argument)
{
osPriority_t prio;
for(;;)
{
prio = osThreadGetPriority(LED1_TaskHandle);
osDelay(5000);
osThreadSetPriority(LED2_TaskHandle,
osPriorityHigh);
osThreadSuspend(LED3_TaskHandle);
osDelay(5000);
osThreadResume(LED3_TaskHandle);
}
}
void StartTask02(void *argument)
{
for(;;)
{
HAL_GPIO_TogglePin(GPIOA,
GPIO_PIN_6);
osThreadSetPriority(NULL,
osPriorityLow);
osDelay(500);
}
}
void StartTask03(void *argument)
{
for(;;)
{
HAL_GPIO_TogglePin(GPIOA,
GPIO_PIN_7);
osDelay(300);
}
}
void StartTask04(void *argument)
{
for(;;)
{
HAL_GPIO_TogglePin(GPIOA,
GPIO_PIN_8);
osDelay(700);
osThreadSuspend(NULL);
}
}
void Error_Handler(void)
{
__disable_irq();
while (1)
{
}
