#include <Arduino_FreeRTOS.h>
#include <semphr.h>
/* Binary Semaphore Handles */
SemaphoreHandle_t S;
SemaphoreHandle_t T;
/* Mutex Handle */
SemaphoreHandle_t serialMutex;
/* Task Functions */
void Task1(void *pvParameters);
void Task2(void *pvParameters);
void setup()
{
Serial.begin(9600);
/* Create Binary Semaphores */
S = xSemaphoreCreateBinary();
T = xSemaphoreCreateBinary();
/* Create Mutex */
serialMutex = xSemaphoreCreateMutex();
/* Check creation */
if(S != NULL && T != NULL && serialMutex != NULL)
{
Serial.println("Semaphores and Mutex Created");
}
/* Initially start Task1 */
xSemaphoreGive(S);
/* Create Task1 */
xTaskCreate(
Task1,
"Task1",
128,
NULL,
2,
NULL
);
/* Create Task2 */
xTaskCreate(
Task2,
"Task2",
128,
NULL,
1,
NULL
);
}
void loop()
{
}
/* Task1 */
void Task1(void *pvParameters)
{
while(1)
{
/* Wait for S */
if(xSemaphoreTake(S, portMAX_DELAY) == pdTRUE)
{
/* Lock Serial */
xSemaphoreTake(serialMutex, portMAX_DELAY);
Serial.println("Task 1 Running");
Serial.print("S Taken -> ");
Serial.println(uxSemaphoreGetCount(S));
/* Unlock Serial */
xSemaphoreGive(serialMutex);
vTaskDelay(500 / portTICK_PERIOD_MS);
/* Signal Task2 */
xSemaphoreGive(T);
/* Lock Serial */
xSemaphoreTake(serialMutex, portMAX_DELAY);
Serial.print("T Given -> ");
Serial.println(uxSemaphoreGetCount(T));
Serial.println();
/* Unlock Serial */
xSemaphoreGive(serialMutex);
}
}
}
/* Task2 */
void Task2(void *pvParameters)
{
while(1)
{
/* Wait for T */
if(xSemaphoreTake(T, portMAX_DELAY) == pdTRUE)
{
/* Lock Serial */
xSemaphoreTake(serialMutex, portMAX_DELAY);
Serial.println("Task 2 Running");
Serial.print("T Taken -> ");
Serial.println(uxSemaphoreGetCount(T));
/* Unlock Serial */
xSemaphoreGive(serialMutex);
vTaskDelay(500 / portTICK_PERIOD_MS);
/* Signal Task1 */
xSemaphoreGive(S);
/* Lock Serial */
xSemaphoreTake(serialMutex, portMAX_DELAY);
Serial.print("S Given -> ");
Serial.println(uxSemaphoreGetCount(S));
Serial.println();
/* Unlock Serial */
xSemaphoreGive(serialMutex);
}
}
}
