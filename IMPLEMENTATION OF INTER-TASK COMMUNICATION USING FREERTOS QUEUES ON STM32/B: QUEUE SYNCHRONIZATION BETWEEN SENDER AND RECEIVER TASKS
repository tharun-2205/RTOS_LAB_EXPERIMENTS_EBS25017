#include "FreeRTOS.h"
#include "task.h"
#include "queue.h"
#include "cmsis_os.h"
#include "main.h"
#include <stdint.h>
#include <stdio.h>
/* Queue Handle --------------------------------------------------------------*/
QueueHandle_t xQueue;
/* Task Handles --------------------------------------------------------------*/
TaskHandle_t SenderHandle;
/* UART Register Definitions -------------------------------------------------*/
#define RCC_BASE 0x40021000UL
#define GPIOA_BASE 0x48000000UL
#define USART2_BASE 0x40004400UL
#define RCC_AHB2ENR (*(volatile uint32_t *)(RCC_BASE + 0x4C))
#define RCC_APB1ENR1 (*(volatile uint32_t *)(RCC_BASE + 0x58))
/* Function Prototypes -------------------------------------------------------*/
void UART2_Init(void);
void UART_Write(char ch);
void SenderTask(void *argument);
void ReceiverTask(void *argument);
/* UART2 Initialization ------------------------------------------------------*/
void UART2_Init(void)
{
RCC_AHB2ENR |= (1 << 0);
RCC_APB1ENR1 |= (1 << 17);
*(volatile uint32_t *)(GPIOA_BASE + 0x00) &= ~(3 << 4);
*(volatile uint32_t *)(GPIOA_BASE + 0x00) |= (2 << 4);
*(volatile uint32_t *)(GPIOA_BASE + 0x20) &= ~(0xF << 8);
*(volatile uint32_t *)(GPIOA_BASE + 0x20) |= (7 << 8);
*(volatile uint32_t *)(USART2_BASE + 0x0C) = 35;
*(volatile uint32_t *)(USART2_BASE + 0x00) =
(1 << 3) |
(1 << 0);
}
/* UART Write Function -------------------------------------------------------*/
void UART_Write(char ch)
{
while(!(*(volatile uint32_t *)(USART2_BASE + 0x1C) & (1 << 7)));
*(volatile uint32_t *)(USART2_BASE + 0x28) = ch;
}
/* printf Redirect -----------------------------------------------------------*/
int __io_putchar(int ch)
{
UART_Write(ch);
return ch;
}
/* FreeRTOS Initialization ---------------------------------------------------*/
void MX_FREERTOS_Init(void)
{
UART2_Init();
/* Create Queue */
xQueue = xQueueCreate(5, sizeof(int));
/* Create Sender Task */
xTaskCreate(SenderTask,
"SenderTask",
128,
NULL,
2,
&SenderHandle);
/* Create Receiver Task */
xTaskCreate(ReceiverTask,
"ReceiverTask",
128,
NULL,
1,
NULL);
}
/* Sender Task ---------------------------------------------------------------*/
void SenderTask(void *argument)
{
int value = 1;
while(1)
{
/* Send 5 values */
for(int i = 0; i < 5; i++)
{
xQueueSend(xQueue,
&value,
portMAX_DELAY);
printf("Sent: %d\r\n", value);
value++;
vTaskDelay(pdMS_TO_TICKS(500));
}
/* Suspend Sender Task */
vTaskSuspend(NULL);
}
}
/* Receiver Task -------------------------------------------------------------*/
void ReceiverTask(void *argument)
{
int receivedData;
while(1)
{
/* Receive only when Queue is Full */
if(uxQueueMessagesWaiting(xQueue) == 5)
{
printf("\r\nQueue Full! Receiving Data...\r\n");
for(int i = 0; i < 5; i++)
{
xQueueReceive(xQueue,
&receivedData,
portMAX_DELAY);
printf("Received: %d\r\n", receivedData);
vTaskDelay(pdMS_TO_TICKS(500));
}
printf("\r\nQueue Empty\r\n\r\n");
/* Resume Sender Task */
vTaskResume(SenderHandle);
}
vTaskDelay(pdMS_TO_TICKS(100));
}
/* Static Allocation for Idle Task -------------------------------------------*/
static StaticTask_t xIdleTaskTCBBuffer;
static StackType_t xIdleStack[configMINIMAL_STACK_SIZE];
void vApplicationGetIdleTaskMemory(
StaticTask_t **ppxIdleTaskTCBBuffer,
StackType_t **ppxIdleTaskStackBuffer,
uint32_t *pulIdleTaskStackSize)
{
*ppxIdleTaskTCBBuffer = &xIdleTaskTCBBuffer;
*ppxIdleTaskStackBuffer = &xIdleStack[0];
*pulIdleTaskStackSize = configMINIMAL_STACK_SIZE;
}
