#include <Arduino_FreeRTOS.h>
#include <queue.h>
/* Queue Handle */
QueueHandle_t myQueue;
/* Task Function Prototypes */
void SenderTask(void *pvParameters);
void ReceiverTask(void *pvParameters);
void setup()
{
Serial.begin(9600);
/* Create Queue
Queue Length = 5
Data Type = int
*/
myQueue = xQueueCreate(5, sizeof(int));
/* Check Queue Creation */
if(myQueue != NULL)
{
Serial.println("Queue Created Successfully");
}
/* Create Sender Task */
xTaskCreate(
SenderTask,
"Sender",
128,
NULL,
2,
NULL
);
/* Create Receiver Task */
xTaskCreate(
ReceiverTask,
"Receiver",
128,
NULL,
1,
NULL
);
}
void loop()
{
}
/* Sender Task */
void SenderTask(void *pvParameters)
{
int value = 1;
while(1)
{
/* Fill Queue Completely */
while(uxQueueSpacesAvailable(myQueue) > 0)
{
xQueueSend(myQueue,
&value,
portMAX_DELAY);
Serial.print("Sent: ");
Serial.println(value);
value++;
vTaskDelay(500 / portTICK_PERIOD_MS);
}
/* Queue Full Message */
Serial.println("Queue FULL");
Serial.println();
/* Wait before next filling cycle */
vTaskDelay(2000 / portTICK_PERIOD_MS);
}
}
/* Receiver Task */
void ReceiverTask(void *pvParameters)
{
int receivedValue;
while(1)
{
/* Start receiving only when queue is FULL */
if(uxQueueMessagesWaiting(myQueue) == 5)
{
Serial.println("Receiver Started");
/* Receive all queue data */
while(uxQueueMessagesWaiting(myQueue) > 0)
{
xQueueReceive(myQueue,
&receivedValue,
portMAX_DELAY);
Serial.print("Received: ");
Serial.println(receivedValue);
vTaskDelay(500 / portTICK_PERIOD_MS);
}
Serial.println("Queue EMPTY");
Serial.println();
}
vTaskDelay(100 / portTICK_PERIOD_MS);
}
}
