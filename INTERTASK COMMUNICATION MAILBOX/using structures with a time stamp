}
Task Creation
xTaskCreate(SenderTask, "Sender", 128, NULL, 1, NULL);
xTaskCreate(ReceiverTask, "Receiver", 128, NULL, 1, NULL);
Important APIs Used
xQueueCreate() // Create mailbox
xQueueOverwrite() // Send (overwrite old data)
xQueueReceive() // Receive data
millis() // Get system time in milliseconds
vTaskDelay() // Task delay
